<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Ellipse?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane
        prefHeight="650" prefWidth="900"
        stylesheets="@../styles/styles.css"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example._0tazo.controller.SelectionController">

    <Rectangle width="900" height="650"
               styleClass="table-background"
               AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"/>

    <Ellipse centerX="450" centerY="325"
             radiusX="360" radiusY="260"
             styleClass="table-ellipse"/>

    <VBox alignment="CENTER" spacing="40"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox alignment="CENTER" spacing="10">
            <Label text="SELECT OPPONENTS" styleClass="welcome-title"/>
            <Label text="How many machines do you want to play against?"
                   styleClass="welcome-subtitle"/>
        </VBox>

        <HBox alignment="CENTER" spacing="24">

            <VBox alignment="CENTER" spacing="10" styleClass="selection-card">
                <Label text="1" styleClass="selection-number"/>
                <Label text="MACHINE" styleClass="selection-label"/>
                <Label text="♠" styleClass="selection-suit"/>
                <Button text="PLAY"
                        styleClass="action-button"
                        onAction="#onSelectOne"
                        prefWidth="120"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10"
                  styleClass="selection-card, selection-card-featured">
                <Label text="2" styleClass="selection-number"/>
                <Label text="MACHINES" styleClass="selection-label"/>
                <Label text="♠ ♥" styleClass="selection-suit"/>
                <Button text="PLAY"
                        styleClass="action-button"
                        onAction="#onSelectTwo"
                        prefWidth="120"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10" styleClass="selection-card">
                <Label text="3" styleClass="selection-number"/>
                <Label text="MACHINES" styleClass="selection-label"/>
                <Label text="♠ ♥ ♦" styleClass="selection-suit"/>
                <Button text="PLAY"
                        styleClass="action-button"
                        onAction="#onSelectThree"
                        prefWidth="120"/>
            </VBox>

        </HBox>

        <Button text="← BACK"
                styleClass="action-button, action-button-secondary"
                onAction="#onBack"
                prefWidth="140"/>

    </VBox>

</AnchorPane>
